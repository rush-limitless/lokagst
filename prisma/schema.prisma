generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id                 String            @id @default(cuid())
  email              String            @unique
  motDePasse         String
  role               Role              @default(LOCATAIRE)
  statut             StatutUtilisateur @default(ACTIF)
  tentativesEchouees Int               @default(0)
  bloqueJusqua       DateTime?
  locataireId        String?           @unique
  locataire          Locataire?        @relation(fields: [locataireId], references: [id])
  creeLe             DateTime          @default(now())
  misAJourLe         DateTime          @updatedAt
  @@map("utilisateurs")
}

enum Role {
  GESTIONNAIRE
  LOCATAIRE
}

enum StatutUtilisateur {
  ACTIF
  BLOQUE
}

model Appartement {
  id           String            @id @default(cuid())
  numero       String            @unique
  etage        Etage
  type         TypeAppartement
  loyerBase    Int
  description  String?
  statut       StatutAppartement @default(LIBRE)
  immeubleId   String?
  immeuble     Immeuble?         @relation(fields: [immeubleId], references: [id])
  baux         Bail[]
  maintenances Maintenance[]
  creeLe       DateTime          @default(now())
  misAJourLe   DateTime          @updatedAt
  @@map("appartements")
}

enum Etage {
  RDC
  PREMIER
  DEUXIEME
  TROISIEME
  QUATRIEME
  CINQUIEME
}

enum TypeAppartement {
  STUDIO
  CHAMBRE
  APPARTEMENT
  APPARTEMENT_MEUBLE
  VILLA
}

enum StatutAppartement {
  LIBRE
  OCCUPE
}

model Locataire {
  id          String          @id @default(cuid())
  nom         String
  prenom      String
  telephone   String
  email       String?         @unique
  numeroCNI   String?
  photo       String?
  garant      String?
  telGarant   String?
  notes       String?
  statut      StatutLocataire @default(ACTIF)
  dateEntree  DateTime
  dateSortie  DateTime?
  baux        Bail[]
  utilisateur Utilisateur?
  emailLogs   EmailLog[]
  maintenances Maintenance[]
  messages    Message[]
  creeLe      DateTime        @default(now())
  misAJourLe  DateTime        @updatedAt
  @@map("locataires")
}

enum StatutLocataire {
  ACTIF
  ARCHIVE
}

model Bail {
  id                    String      @id @default(cuid())
  locataireId           String
  locataire             Locataire   @relation(fields: [locataireId], references: [id])
  appartementId         String
  appartement           Appartement @relation(fields: [appartementId], references: [id])
  dateDebut             DateTime
  dureeMois             Int
  dateFin               DateTime
  montantLoyer          Int
  montantCaution        Int
  cautionPayee          Boolean     @default(false)
  datePremierLoyer      DateTime?
  chargesLocatives      Json        @default("[]")
  totalCharges          Int         @default(0)
  totalMensuel          Int         @default(0)
  jourLimitePaiement    Int         @default(5)
  periodicite           Periodicite @default(MENSUEL)
  delaiGrace            Int         @default(5)
  penaliteType          PenaliteType @default(POURCENTAGE)
  penaliteMontant       Int         @default(5)
  penaliteRecurrente    Boolean     @default(false)
  renouvellementAuto    Boolean     @default(false)
  dureeRenouvellement   Int?
  augmentationLoyer     Int?
  preavisNonRenouv      Int         @default(30)
  preavisResiliation    Int         @default(30)
  seuilMiseEnDemeure    Int         @default(2)
  seuilSuspension       Int         @default(3)
  clausesParticulieres  String?
  signatureLocataire    String?
  dateSignature         DateTime?
  contratUpload         String?
  statut                StatutBail  @default(ACTIF)
  paiements             Paiement[]
  penalites             Penalite[]
  etatsDesLieux         EtatDesLieux[]
  creeLe                DateTime    @default(now())
  misAJourLe            DateTime    @updatedAt
  @@map("baux")
}

enum PenaliteType {
  POURCENTAGE
  MONTANT_FIXE
}

enum Periodicite {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
}

enum StatutBail {
  ACTIF
  SUSPENDU
  RESILIE
  TERMINE
  EXPIRE
}

model Paiement {
  id             String         @id @default(cuid())
  bailId         String
  bail           Bail           @relation(fields: [bailId], references: [id])
  montant        Int
  montantLoyer   Int            @default(0)
  montantCharges Int            @default(0)
  montantCaution Int            @default(0)
  montantAutres  Int            @default(0)
  notesAutres    String?
  penalites      Int            @default(0)
  totalDu        Int            @default(0)
  moisConcerne   DateTime
  datePaiement   DateTime       @default(now())
  modePaiement   ModePaiement
  statut         StatutPaiement @default(PAYE)
  resteDu        Int            @default(0)
  preuvePaiement String?
  valide         Boolean        @default(true)
  notes          String?
  creeLe         DateTime       @default(now())
  @@map("paiements")
}

enum ModePaiement {
  VIREMENT_BANCAIRE
  ORANGE_MONEY
}

enum StatutPaiement {
  PAYE
  PARTIELLEMENT_PAYE
}

model Penalite {
  id           String   @id @default(cuid())
  bailId       String
  bail         Bail     @relation(fields: [bailId], references: [id])
  moisConcerne DateTime
  montant      Int
  motif        String
  appliqueLe   DateTime @default(now())
  payee        Boolean  @default(false)
  @@map("penalites")
}

model EmailLog {
  id           String    @id @default(cuid())
  locataireId  String
  locataire    Locataire @relation(fields: [locataireId], references: [id])
  type         TypeEmail
  sujet        String
  contenu      String
  destinataire String
  envoyeLe     DateTime  @default(now())
  @@map("email_logs")
}

enum TypeEmail {
  RAPPEL_ECHEANCE
  RAPPEL_PAIEMENT
  RECU_PAIEMENT
  NOTIFICATION_PENALITE
  MISE_EN_DEMEURE
  SUSPENSION_BAIL
  RENOUVELLEMENT_BAIL
  EXPIRATION_BAIL
  NON_RENOUVELLEMENT
}

model Maintenance {
  id             String            @id @default(cuid())
  appartementId  String
  appartement    Appartement       @relation(fields: [appartementId], references: [id])
  locataireId    String
  locataire      Locataire         @relation(fields: [locataireId], references: [id])
  titre          String
  description    String
  photos         String[]
  statut         StatutMaintenance @default(SIGNALE)
  priorite       Priorite          @default(NORMALE)
  technicien     String?
  commentaire    String?
  creeLe         DateTime          @default(now())
  misAJourLe     DateTime          @updatedAt
  @@map("maintenances")
}

enum StatutMaintenance {
  SIGNALE
  EN_COURS
  RESOLU
}

enum Priorite {
  BASSE
  NORMALE
  URGENTE
}

model Message {
  id           String   @id @default(cuid())
  locataireId  String
  locataire    Locataire @relation(fields: [locataireId], references: [id])
  expediteur   ExpMessage
  contenu      String
  lu           Boolean  @default(false)
  creeLe       DateTime @default(now())
  @@map("messages")
}

enum ExpMessage {
  GESTIONNAIRE
  LOCATAIRE
}

model EtatDesLieux {
  id            String       @id @default(cuid())
  bailId        String
  bail          Bail         @relation(fields: [bailId], references: [id])
  type          TypeEDL
  date          DateTime     @default(now())
  pieces        Json         @default("[]")
  observations  String?
  photos        String[]
  signatureLocataire String?
  signatureGestionnaire String?
  creeLe        DateTime     @default(now())
  @@map("etats_des_lieux")
}

enum TypeEDL {
  ENTREE
  SORTIE
}

model AuditLog {
  id          String   @id @default(cuid())
  utilisateur String
  action      String
  entite      String
  entiteId    String?
  details     String?
  creeLe      DateTime @default(now())
  @@map("audit_logs")
}

model Immeuble {
  id          String        @id @default(cuid())
  nom         String
  adresse     String
  ville       String
  quartier    String?
  appartements Appartement[]
  creeLe      DateTime      @default(now())
  misAJourLe  DateTime      @updatedAt
  @@map("immeubles")
}
