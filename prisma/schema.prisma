generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id                 String            @id @default(cuid())
  email              String            @unique
  motDePasse         String
  role               Role              @default(LOCATAIRE)
  statut             StatutUtilisateur @default(ACTIF)
  tentativesEchouees Int               @default(0)
  bloqueJusqua       DateTime?
  locataireId        String?           @unique
  creeLe             DateTime          @default(now())
  misAJourLe         DateTime          @updatedAt
  locataire          Locataire?        @relation(fields: [locataireId], references: [id])

  @@map("utilisateurs")
}

model Appartement {
  id           String            @id @default(cuid())
  numero       String            @unique
  etage        Etage
  type         TypeAppartement
  loyerBase    Int
  description  String?
  statut       StatutAppartement @default(LIBRE)
  creeLe       DateTime          @default(now())
  misAJourLe   DateTime          @updatedAt
  immeubleId   String?
  immeuble     Immeuble?         @relation(fields: [immeubleId], references: [id])
  baux         Bail[]
  maintenances Maintenance[]

  @@map("appartements")
}

model Locataire {
  id                 String          @id @default(cuid())
  nom                String
  prenom             String
  telephone          String
  email              String?         @unique
  numeroCNI          String?
  photo              String?
  statut             StatutLocataire @default(ACTIF)
  dateEntree         DateTime
  dateSortie         DateTime?
  creeLe             DateTime        @default(now())
  misAJourLe         DateTime        @updatedAt
  garant             String?
  notes              String?
  telGarant          String?
  reglementInterieur String?
  baux               Bail[]
  emailLogs          EmailLog[]
  maintenances       Maintenance[]
  messages           Message[]
  utilisateur        Utilisateur?

  @@map("locataires")
}

model Bail {
  id                   String         @id @default(cuid())
  locataireId          String
  appartementId        String
  dateDebut            DateTime
  dureeMois            Int
  dateFin              DateTime
  montantLoyer         Int
  montantCaution       Int
  statut               StatutBail     @default(ACTIF)
  creeLe               DateTime       @default(now())
  misAJourLe           DateTime       @updatedAt
  augmentationLoyer    Int?
  chargesLocatives     Json           @default("[]")
  clausesParticulieres String?
  delaiGrace           Int            @default(5)
  dureeRenouvellement  Int?
  jourLimitePaiement   Int            @default(5)
  penaliteMontant      Int            @default(5)
  penaliteRecurrente   Boolean        @default(false)
  penaliteType         PenaliteType   @default(POURCENTAGE)
  preavisNonRenouv     Int            @default(30)
  preavisResiliation   Int            @default(30)
  renouvellementAuto   Boolean        @default(false)
  seuilMiseEnDemeure   Int            @default(2)
  seuilSuspension      Int            @default(3)
  totalCharges         Int            @default(0)
  totalMensuel         Int            @default(0)
  contratUpload        String?
  dateSignature        DateTime?
  signatureLocataire   String?
  periodicite          Periodicite    @default(MENSUEL)
  cautionPayee         Boolean        @default(false)
  datePremierLoyer     DateTime?
  impotsTaxes          Json           @default("[]")
  totalImpotsTaxes     Int            @default(0)
  appartement          Appartement    @relation(fields: [appartementId], references: [id])
  locataire            Locataire      @relation(fields: [locataireId], references: [id])
  etatsDesLieux        EtatDesLieux[]
  paiements            Paiement[]
  penalites            Penalite[]

  @@map("baux")
}

model Paiement {
  id             String         @id @default(cuid())
  bailId         String
  montant        Int
  moisConcerne   DateTime
  datePaiement   DateTime       @default(now())
  statut         StatutPaiement @default(PAYE)
  resteDu        Int            @default(0)
  notes          String?
  creeLe         DateTime       @default(now())
  montantCharges Int            @default(0)
  montantLoyer   Int            @default(0)
  penalites      Int            @default(0)
  totalDu        Int            @default(0)
  modePaiement   ModePaiement
  preuvePaiement String?
  montantAutres  Int            @default(0)
  montantCaution Int            @default(0)
  notesAutres    String?
  valide         Boolean        @default(true)
  bail           Bail           @relation(fields: [bailId], references: [id])

  @@map("paiements")
}

model Penalite {
  id           String   @id @default(cuid())
  bailId       String
  moisConcerne DateTime
  montant      Int
  motif        String
  appliqueLe   DateTime @default(now())
  payee        Boolean  @default(false)
  bail         Bail     @relation(fields: [bailId], references: [id])

  @@map("penalites")
}

model EmailLog {
  id           String    @id @default(cuid())
  locataireId  String
  type         TypeEmail
  sujet        String
  contenu      String
  destinataire String
  envoyeLe     DateTime  @default(now())
  locataire    Locataire @relation(fields: [locataireId], references: [id])

  @@map("email_logs")
}

model Maintenance {
  id            String            @id @default(cuid())
  appartementId String
  locataireId   String
  titre         String
  description   String
  photos        String[]
  statut        StatutMaintenance @default(SIGNALE)
  priorite      Priorite          @default(NORMALE)
  technicien    String?
  commentaire   String?
  creeLe        DateTime          @default(now())
  misAJourLe    DateTime          @updatedAt
  appartement   Appartement       @relation(fields: [appartementId], references: [id])
  locataire     Locataire         @relation(fields: [locataireId], references: [id])

  @@map("maintenances")
}

model Message {
  id          String     @id @default(cuid())
  locataireId String
  expediteur  ExpMessage
  contenu     String
  lu          Boolean    @default(false)
  creeLe      DateTime   @default(now())
  locataire   Locataire  @relation(fields: [locataireId], references: [id])

  @@map("messages")
}

model EtatDesLieux {
  id                    String   @id @default(cuid())
  bailId                String
  type                  TypeEDL
  date                  DateTime @default(now())
  pieces                Json     @default("[]")
  observations          String?
  photos                String[]
  signatureLocataire    String?
  signatureGestionnaire String?
  creeLe                DateTime @default(now())
  bail                  Bail     @relation(fields: [bailId], references: [id])

  @@map("etats_des_lieux")
}

model AuditLog {
  id          String   @id @default(cuid())
  utilisateur String
  action      String
  entite      String
  entiteId    String?
  details     String?
  creeLe      DateTime @default(now())

  @@map("audit_logs")
}

model Immeuble {
  id           String        @id @default(cuid())
  nom          String
  adresse      String
  ville        String
  quartier     String?
  creeLe       DateTime      @default(now())
  misAJourLe   DateTime      @updatedAt
  appartements Appartement[]
  depenses     Depense[]

  @@map("immeubles")
}

model Depense {
  id           String           @id @default(cuid())
  immeubleId   String?
  categorie    CategorieDepense
  description  String
  montant      Int
  date         DateTime         @default(now())
  fournisseur  String?
  reference    String?
  justificatif String?
  creeLe       DateTime         @default(now())
  immeuble     Immeuble?        @relation(fields: [immeubleId], references: [id])

  @@map("depenses")
}

enum Role {
  GESTIONNAIRE
  LOCATAIRE
  SUPER_ADMIN
}

enum StatutUtilisateur {
  ACTIF
  BLOQUE
}

enum Etage {
  RDC
  PREMIER
  DEUXIEME
  TROISIEME
  QUATRIEME
  CINQUIEME
  AUTRE
}

enum TypeAppartement {
  STUDIO
  CHAMBRE
  APPARTEMENT
  APPARTEMENT_MEUBLE
  VILLA
  STUDIO_MEUBLE
  CHAMBRE_MEUBLE
  SALLE_CONFERENCE
}

enum StatutAppartement {
  LIBRE
  OCCUPE
}

enum StatutLocataire {
  ACTIF
  ARCHIVE
}

enum PenaliteType {
  POURCENTAGE
  MONTANT_FIXE
}

enum Periodicite {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
  JOURNALIER
  NON_APPLICABLE
}

enum StatutBail {
  ACTIF
  RESILIE
  TERMINE
  EXPIRE
  SUSPENDU
}

enum ModePaiement {
  VIREMENT_BANCAIRE
  ORANGE_MONEY
}

enum StatutPaiement {
  PAYE
  PARTIELLEMENT_PAYE
}

enum TypeEmail {
  RAPPEL_PAIEMENT
  RECU_PAIEMENT
  EXPIRATION_BAIL
  RAPPEL_ECHEANCE
  NOTIFICATION_PENALITE
  MISE_EN_DEMEURE
  SUSPENSION_BAIL
  RENOUVELLEMENT_BAIL
  NON_RENOUVELLEMENT
}

enum StatutMaintenance {
  SIGNALE
  EN_COURS
  RESOLU
}

enum Priorite {
  BASSE
  NORMALE
  URGENTE
}

enum ExpMessage {
  GESTIONNAIRE
  LOCATAIRE
}

enum TypeEDL {
  ENTREE
  SORTIE
}

enum CategorieDepense {
  TRAVAUX
  ENTRETIEN
  ASSURANCE
  TAXE_FONCIERE
  EAU_ELECTRICITE
  FRAIS_GESTION
  AUTRE
}
